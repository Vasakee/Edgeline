{
  "name": "edgeline",
  "version": "0.1.0",
  "private": true,
  "description": "Solana-based autonomous sports trading agent",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:api": "pnpm --filter @edgeline/api dev",
    "dev:web": "pnpm --filter @edgeline/web dev",
    "build": "pnpm --filter @edgeline/shared-types build && pnpm --filter @edgeline/api build && pnpm --filter @edgeline/web build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  }
}
