# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to a solana-keygen JSON keypair file ([...64 bytes...])
SOLANA_WALLET_PATH=~/.config/solana/id.json

# TxLINE API
# Devnet: https://txline-dev.txodds.com
# Mainnet: https://txline.txodds.com
TXLINE_BASE_URL=https://txline-dev.txodds.com
# Comma-separated league IDs; leave empty for standard World Cup bundle (service level 1)
SELECTED_LEAGUES=
# Set to true to use the free World Cup tier (service level 1, no TxL required)
USE_FREE_WORLDCUP_TIER=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017/edgeline

# Polling
POLL_INTERVAL_MS=20000
API_HOST=0.0.0.0

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
